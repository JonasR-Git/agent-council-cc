{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/agent-council/plan.schema.json",
  "title": "CouncilSolutionPlan",
  "type": "object",
  "required": ["agent", "summary", "approach", "steps"],
  "properties": {
    "agent": {
      "type": "string",
      "description": "Author id: claude | codex | grok"
    },
    "summary": {
      "type": "string",
      "description": "2-4 sentence pitch of the plan"
    },
    "approach": {
      "type": "string",
      "description": "The core idea in one paragraph"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["n", "title", "detail"],
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "detail": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk"],
        "properties": {
          "risk": { "type": "string" },
          "mitigation": { "type": "string" },
          "severity": { "type": "string", "enum": ["P0", "P1", "P2"] }
        }
      }
    },
    "tradeoffs": { "type": "array", "items": { "type": "string" } },
    "effort": { "type": "string", "enum": ["S", "M", "L", "XL"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
