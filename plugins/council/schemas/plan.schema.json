{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/agent-council/plan.schema.json",
  "title": "CouncilSolutionPlan",
  "type": "object",
  "required": ["approach", "steps"],
  "properties": {
    "agent": {
      "type": "string",
      "description": "Author id: claude | codex | grok"
    },
    "summary": {
      "type": "string",
      "description": "2-4 sentence pitch of the plan"
    },
    "approach": {
      "type": "string",
      "description": "The core idea in one paragraph"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "detail": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk"],
        "properties": {
          "risk": { "type": "string" },
          "mitigation": { "type": "string" },
          "severity": { "type": "string", "description": "P0|P1|P2 - normalized by the harness" }
        }
      }
    },
    "tradeoffs": { "type": "array", "items": { "type": "string" } },
    "effort": { "type": "string", "description": "S|M|L|XL - unknown values normalize to M" },
    "confidence": { "type": "number", "description": "0..1, defaulted by the harness" }
  }
}
