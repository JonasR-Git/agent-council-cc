{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/agent-council/audit-report.schema.json",
  "title": "AuditReport",
  "description": "The council audit-engine output envelope (`/council:review --mode run`; docs/audit-schema.md §8): gate verdict, prioritized risk register, coverage matrix, governance decisions, false-positive rate and provenance.",
  "type": "object",
  "required": ["schemaVersion", "gate", "register", "coverage"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "generatedAt": { "type": "string" },
    "target": { "type": "object" },
    "gate": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail", "indeterminate"] },
        "reason": { "type": "string" },
        "newHighSeverity": { "type": "integer", "minimum": 0 }
      }
    },
    "register": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ruleId", "lens", "severity"],
        "properties": {
          "ruleId": { "type": "string" },
          "fingerprint": { "type": "string" },
          "lens": { "type": "string" },
          "severity": { "type": "string", "enum": ["P0", "P1", "P2", "nit"] }
        }
      }
    },
    "proposals": { "type": "array", "items": { "type": "object" } },
    "coverage": {
      "type": "object",
      "required": ["total", "mandatory"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "byState": { "type": "object" },
        "mandatory": {
          "type": "object",
          "required": ["total", "done", "complete"],
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "done": { "type": "integer", "minimum": 0 },
            "complete": { "type": "boolean" }
          }
        },
        "uncovered": { "type": "array", "items": { "type": "object" } }
      }
    },
    "falsePositiveRate": { "type": ["object", "null"] },
    "governance": { "type": "object" },
    "provenance": { "type": "object" }
  }
}
