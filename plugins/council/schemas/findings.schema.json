{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/agent-council/findings.schema.json",
  "title": "CouncilReviewFindings",
  "type": "object",
  "required": ["findings"],
  "properties": {
    "agent": {
      "type": "string",
      "description": "Reviewer id: claude | codex | grok"
    },
    "summary": {
      "type": "string",
      "description": "2-5 sentence overall assessment"
    },
    "verdict": {
      "type": "string",
      "description": "approve|approve_with_nits|request_changes|block - unknown values normalize to request_changes"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "description": "P0|P1|P2|nit - unknown values normalize to P2" },
          "category": {
            "type": "string",
            "description": "bug|security|concurrency|data-loss|auth|compliance|performance|design|test|dx|other - free-form tolerated"
          },
          "title": { "type": "string" },
          "detail": { "type": "string" },
          "file": { "type": ["string", "null"] },
          "line": { "description": "integer preferred; numeric strings are coerced by the harness" },
          "confidence": { "description": "0..1 number preferred; coerced/defaulted by the harness" }
        }
      }
    }
  }
}
